# Agile Agent — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit real credentials.

# ── Jira ─────────────────────────────────────────────
# Secret token set when creating the Jira webhook
JIRA_WEBHOOK_SECRET=ATATT3xFfGF0k2YLsZWDm0fZlm8CM4FBT52eFxrRa3fhuWeTbPgR2EMmqQkEGCjXGIb9GR3am9kzuTyPzweGgRDH1d0j-ofmEaCDIVTncrRYJ1SCLz2NcloTx_d1UC138R9Vs-SGp4O60Sg7vZrNMp3IkB2R2zXrxg2BqiC0sAi2sFYfB6qaC7E=13D0B5F0

# ── LLM provider ────────────────────────────────────
# Default: Anthropic Claude 3.5 Sonnet
# To use GPT-4o, set OPENAI_API_KEY instead and update the workflow node.
# To use Ollama locally, set OLLAMA_BASE_URL instead.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ── Slack ────────────────────────────────────────────
# Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Channel ID for the daily digest (e.g. C0123456789)
# Find it: right-click the channel in Slack → View channel details → copy ID
SLACK_CHANNEL_ID=C0123456789

# ── Sprint config ────────────────────────────────────
# ISO 8601 date — used by the scope creep sentinel to determine mid-sprint
SPRINT_START_DATE=2025-01-06

# Token count above which a ticket thread triggers scope analysis
# Default 800 is a reasonable starting point; tune based on your team's ticket verbosity
TOKEN_THRESHOLD=800

# Cron schedule for the daily digest (default: weekdays at 8:00 AM)
# Format: min hour day month weekday
CRON_SCHEDULE=0 8 * * 1-5
