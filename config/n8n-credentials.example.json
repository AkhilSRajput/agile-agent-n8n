{
  "_comment": "This file documents the credential names the workflows expect in n8n. Create matching credentials in n8n Settings → Credentials. Do not store real values here.",
  "credentials": [
    {
      "name": "Jira API",
      "type": "jiraSoftwareCloudApi",
      "required_by": ["scope-creep-sentinel.json", "daily-digest.json", "blocker-router.json"],
      "fields": {
        "email": "your-jira-account-email@company.com",
        "apiToken": "YOUR_JIRA_API_TOKEN",
        "domain": "your-org.atlassian.net"
      }
    },
    {
      "name": "Slack OAuth",
      "type": "slackOAuth2Api",
      "required_by": ["scope-creep-sentinel.json", "daily-digest.json", "blocker-router.json"],
      "fields": {
        "accessToken": "xoxb-your-slack-bot-token"
      }
    },
    {
      "name": "Anthropic",
      "type": "httpHeaderAuth",
      "required_by": ["scope-creep-sentinel.json", "daily-digest.json", "blocker-router.json"],
      "fields": {
        "name": "x-api-key",
        "value": "YOUR_ANTHROPIC_API_KEY"
      },
      "note": "To swap to OpenAI, create an 'OpenAI' credential (type: openAiApi) and update the HTTP Request node in each workflow."
    }
  ]
}
